#include<bits/stdc++.h>
#define endl "\n"
#define ll long long
using namespace std;
int main(){
	ios_base::sync_with_stdio(false);cin.tie(NULL);cout.tie(NULL);
	ll n; cin >> n;
	ll dem = 0 ; 
	for (ll i = 1 ; i * i <= n ; i++){
		if (n % i == 0) {
		dem ++;
			if (i * i != n){
				dem++;
			}
		}
		
	}
	cout << dem << endl;
	return 0;
}
